{
  "name": "@dailyreport/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "db:bootstrap": "tsx src/bootstrap.ts",
    "db:rotate-integration-key": "tsx src/rotate-integration-key.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "npm run build && node --test dist/*.test.js dist/http/*.test.js dist/http/security/*.test.js"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "nodemailer": "^8.0.10",
    "telegraf": "^4.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.6.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
