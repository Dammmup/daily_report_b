{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/telegram/motivation-cron",
      "schedule": "30 4 * * 1-5"
    },
    {
      "path": "/api/telegram/personal-focus-cron",
      "schedule": "45 4 * * 1-5"
    },
    {
      "path": "/api/telegram/report-reminder-cron",
      "schedule": "30 11 * * 1-5"
    },
    {
      "path": "/api/telegram/group-digest-cron",
      "schedule": "30 12 * * 1-5"
    },
    {
      "path": "/api/telegram/fun-cron",
      "schedule": "13 5 * * 1"
    },
    {
      "path": "/api/telegram/fun-cron",
      "schedule": "47 7 * * 2"
    },
    {
      "path": "/api/telegram/fun-cron",
      "schedule": "22 9 * * 3"
    },
    {
      "path": "/api/telegram/fun-cron",
      "schedule": "36 11 * * 4"
    },
    {
      "path": "/api/telegram/fun-cron",
      "schedule": "8 6 * * 5"
    }
  ]
}
