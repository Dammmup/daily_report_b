PORT=4000
BUSINESS_TIME_ZONE=Asia/Almaty
MONGODB_URI=mongodb://127.0.0.1:27017/dailyreport_erp
MONGODB_DB=dailyreport
JWT_SECRET=change-this-secret
INTEGRATION_ENCRYPTION_KEY=
# Отдельный секрет для подписи OAuth-state (фолбэк — JWT_SECRET). Желательно задать свой.
OAUTH_STATE_SECRET=
ADMIN_EMAIL=admin@erp.local
ADMIN_PASSWORD=change-this-admin-password
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TELEGRAM_MODEL=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DailyReport ERP <no-reply@example.com>
ALLOW_DEV_VERIFICATION_CODE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_MODE=polling
# Секрет вебхука Telegram (>=16 символов). Передаётся в setWebhook как secret_token
# и проверяется в заголовке X-Telegram-Bot-Api-Secret-Token на каждом апдейте.
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
FRONTEND_URL=https://daily-report-f.vercel.app
ALLOWED_ORIGINS=https://daily-report-f.vercel.app,http://127.0.0.1:5173,http://localhost:5173
